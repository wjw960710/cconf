# git 腳本用的 token
GIT_TOKEN=

# 專案喚醒的編輯器順序(這裡沒填寫到的編輯器就是尚未支持)
OPEN_EDITOR=webstorm>idea>code

# ccf serve / srv 的預設監聽 host / port（port 被占用時自動 +1 試到可用 port）
CLI_SERVE_HOST=localhost
CLI_SERVE_PORT=11737

# 指定專案目錄，規則：<project>_DIR_PATH
CHAT_DIR_PATH=D:\chat
# 指定專案喚醒的編輯器順序，規則：<project>_OPEN_EDITOR
CHAT_OPEN_EDITOR=